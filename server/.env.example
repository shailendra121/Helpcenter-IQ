# Copy to .env for local dev. Never commit the real .env file.

NODE_ENV=development
PORT=4000

# Postgres — see infra/docker/docker-compose.yml for local dev instance
DATABASE_URL=postgresql://helpcenteriq:helpcenteriq@localhost:5432/helpcenteriq

# Zendesk OAuth client (issued after Marketplace developer portal registration)
# See docs/adr/0004-zendesk-auth-global-oauth.md
ZENDESK_OAUTH_CLIENT_ID=
ZENDESK_OAUTH_CLIENT_SECRET=
ZENDESK_MARKETPLACE_APP_ID=
ZENDESK_MARKETPLACE_ORG_ID=

# ZAF JWT verification (see server/src/zendesk/ — validates iframe request origin)
ZAF_APP_PUBLIC_KEY_PATH=./secrets/zaf_app_public_key.pem

# AI provider — see docs/adr/0003-ai-provider-abstraction-and-pii-masking.md
# and docs/adr/0006-google-gemini-default-ai-provider.md
# NOTE: free tier is dev/test only (synthetic or masked data) — production
# requires the paid tier per ADR-0006. Never point this at real customer data.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Encryption key for storing Zendesk OAuth tokens at rest
TOKEN_ENCRYPTION_KEY=
